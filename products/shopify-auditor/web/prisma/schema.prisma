generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Session {
  id            String  @id
  shop          String
  state         String
  isOnline      Boolean @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
  refreshToken  String?
  refreshTokenExpires DateTime?
}

model Merchant {
  id            Int      @id @default(autoincrement())
  shopDomain    String   @unique
  plan          String   @default("free")
  storePassword String?
  installedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  scans         Scan[]
}

model Scan {
  id            Int       @id @default(autoincrement())
  merchantId    Int
  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  status        String    @default("pending")
  scanType      String    @default("static")
  score         Int?
  themeName     String    @default("")
  templateCount Int       @default(0)
  reportToken   String?   @unique
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  findings      Finding[]

  @@index([merchantId, status])
  @@index([merchantId, startedAt])
}

model Finding {
  id          Int    @id @default(autoincrement())
  scanId      Int
  scan        Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  criterionId String
  severity    String
  element     String
  filePath    String
  line        Int    @default(0)
  message     String
  suggestion  String
  source      String @default("static")
  pageUrl     String @default("")

  @@index([scanId])
  @@index([scanId, criterionId])
  @@index([scanId, severity])
}
